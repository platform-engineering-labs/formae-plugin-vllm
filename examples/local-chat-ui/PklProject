amends "pkl:Project"

// Portable local example: all schemas come from published packages. The compose
// schema must be >= 0.1.3, which added the resolvable `variables` field this
// example uses.
dependencies {
  ["vllm"] {
    uri = "package://hub.platform.engineering/plugins/vllm/schema/pkl/vllm/vllm@0.1.0"
  }
  ["compose"] {
    uri = "package://hub.platform.engineering/plugins/compose/schema/pkl/compose/compose@0.1.3"
  }
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.86.0"
  }
}

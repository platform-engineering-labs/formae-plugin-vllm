/*
 * Basic Example
 *
 * This example shows how to define resources using your plugin.
 * Run with: formae apply --mode reconcile --watch examples/basic/main.pkl
 */
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@vllm/core/vllm.pkl"

forma {
  new formae.Stack {
    label = "default"
    description = "Default stack for example resources"
  }

  new formae.Target {
    label = "my-target"
    namespace = "VLLM"
    // Add your provider-specific configuration here
    // For typed config, create a Config class in your schema:
    //   config = new vllm.Config { region = "us-east-1" }
    config = new Mapping {
      ["region"] = "us-east-1"
    }
  }

  new vllm.ExampleResource {
    label = "my-resource"
    name = "My Example Resource"
    description = "This is an example resource"
    region = "us-east-1"

    endpoint = new vllm.Endpoint {
      url = "https://api.vllm.com"
      port = 8080
      protocol = "https"
    }

    tags = new Listing {
      new vllm.Tag { key = "Environment"; value = "development" }
      new vllm.Tag { key = "Team"; value = "platform" }
    }
  }
}

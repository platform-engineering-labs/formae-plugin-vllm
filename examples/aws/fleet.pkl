/*
 * Fleet app layer: the LoRA-adapter set for the vLLM nodes plus a chat-UI,
 * wired to the AWS instances declared in the vllm-fleet-infra stack. Every
 * cross-stack edge is a formae resolvable resolved at apply time — no copied
 * values, no env bridge. Apply AFTER fleet-infra.pkl is up and vLLM is serving
 * on each node.
 *
 * The stack auto-reconciles every 30s: a node that restarts and loses its
 * (ephemeral) adapters is healed hands-off.
 */
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@aws/ec2/instance.pkl"
import "@vllm/core/vllm.pkl"
import "@compose/compose.pkl"

local base = "Qwen/Qwen2.5-0.5B-Instruct"

// Typed cross-stack handle to a node's EC2 instance (declared in the infra
// stack). `.publicIp` reads back the instance's public IP at apply time.
local function node(suffix: String): instance.InstanceResolvable = new {
  label = "vllm-node-\(suffix)"
  stack = "vllm-fleet-infra"
}

// One vLLM target per node, each resolving its host from the node's public IP.
local nodeA = new formae.Target {
  label = "node-a"
  config = new vllm.Config { host = node("a").publicIp; port = 8000 }
}
local nodeB = new formae.Target {
  label = "node-b"
  config = new vllm.Config { host = node("b").publicIp; port = 8000 }
}

// Local Docker target for the chat-UI container.
local docker = new formae.Target {
  label = "docker"
  config = new compose.Config {}
}

// node-a's chat adapter — pulled into a local so the chat-UI can wire its MODEL
// from the adapter's read-back id (`.res.id`).
local chatAdapter = new vllm.LoRAAdapter {
  label = "node-a-chat"
  target = nodeA.res
  loraName = "chat"
  loraPath = "/adapters/chat"
  baseModelName = base
}

forma {
  new formae.Stack {
    label = "vllm-fleet"
    description = "Declared LoRA adapter set + chat UI across the vLLM fleet"
    policies {
      new formae.AutoReconcilePolicy { label = "fleet-reconcile"; interval = 30.s }
    }
  }

  nodeA
  nodeB
  docker

  // node-a: chat (referenced by the UI) + jailbreak-detector.
  chatAdapter
  new vllm.LoRAAdapter {
    label = "node-a-jailbreak-detector"
    target = nodeA.res
    loraName = "jailbreak-detector"
    loraPath = "/adapters/jailbreak-detector"
    baseModelName = base
  }

  // node-b: the full adapter set.
  new vllm.LoRAAdapter {
    label = "node-b-chat"
    target = nodeB.res
    loraName = "chat"
    loraPath = "/adapters/chat"
    baseModelName = base
  }
  new vllm.LoRAAdapter {
    label = "node-b-jailbreak-detector"
    target = nodeB.res
    loraName = "jailbreak-detector"
    loraPath = "/adapters/jailbreak-detector"
    baseModelName = base
  }

  // The chat UI — wired by resolvables: VLLM_HOST from node-a's public IP, MODEL
  // from the chat adapter's read-back id. Both flow through the compose
  // `variables` field, where ${VAR} interpolates into the container env.
  new compose.Stack {
    label = "chat-ui"
    target = docker.res
    projectName = "vllm-chat-ui"
    variables {
      ["VLLM_HOST"] = node("a").publicIp
      ["MODEL"] = chatAdapter.res.id
    }
    composeFile = """
      services:
        chat-ui:
          image: formae-chat-ui:demo
          environment:
            VLLM_BASE_URL: "http://${VLLM_HOST}:8000"
            MODEL: "${MODEL}"
          ports:
            - "8088:8080"
      """
  }
}

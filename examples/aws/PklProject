amends "pkl:Project"

dependencies {
  // Reference local vLLM plugin schema during development (for adapter.pkl)
  // IMPORTANT: The alias must match the package name from the schema's PklProject
  ["vllm"] = import("../../schema/pkl/PklProject")

  // Formae schema - fetched from public registry
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.84.0"
  }

  // AWS plugin schema (for box.pkl) - fetched from public registry.
  ["aws"] {
    uri = "package://hub.platform.engineering/plugins/aws/schema/pkl/aws/aws@0.1.3"
  }
}

amends "pkl:Project"

// Local, GPU-free infra-graph example. Imports the vLLM and compose plugin
// schemas from the working trees so the unreleased `LoRAAdapterResolvable` and
// compose `variables` are available. Once compose ships a release with
// `variables`, switch the compose dep to the published package.
dependencies {
  ["vllm"] = import("../../schema/pkl/PklProject")
  ["compose"] = import("../../../formae-plugin-compose/schema/pkl/PklProject")
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.86.0"
  }
}

/// Plugin configuration.
/// Customize this with plugin-specific settings that users can set in formae.conf.pkl.
///
/// Users import this via: import "plugins:/Vllm.pkl" as Vllm
///
/// Then use it in their formae.conf.pkl:
///   agent {
///       resourcePlugins {
///           new Vllm.PluginConfig {
///               rateLimit { maxRequestsPerSecond = 5 }
///           }
///       }
///   }
open module vllm.Config

extends "formae:/Config.pkl"

class PluginConfig extends BaseResourcePluginConfig {
    type = "vllm"  // Plugin name used by formae to identify this plugin.

    // Add custom configuration fields here, e.g.:
    // defaultRegion: String = "us-east-1"
    // maxRetries: Int = 3
}
